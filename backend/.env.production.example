# ===== Backend production (.env) =====
APP_PORT=8080
APP_ENV=production

# Same-origin via Nginx → boleh diisi domain (CORS jadi tidak relevan saat same-origin)
CORS_ORIGIN=https://madrasah.example.com

# Database (buat user khusus, JANGAN pakai root di produksi)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=sim_user
DB_PASSWORD=ISI_PASSWORD_KUAT
DB_NAME=sim_madrasah

# JWT — WAJIB ganti: hasil dari `openssl rand -hex 32`
JWT_SECRET=GANTI_DENGAN_HEX_ACAK_64_KARAKTER
JWT_EXPIRY_MINUTES=120

# WAJIB true di HTTPS agar cookie aman
COOKIE_SECURE=true

# WAJIB diisi rabdom panjang (mis. openssl rand -hex 32) — dipakai n8n untuk bot-login
BOT_SHARED_SECRET=GANTI_DENGAN_HEX_ACAK_64_KARAKTER
